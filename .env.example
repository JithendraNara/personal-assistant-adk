# Personal Assistant ADK — Environment Configuration
# Copy this file to .env and fill in your values

# ─── LLM Provider (pick ONE — set the key for whichever you use) ──────────────
#
# Gemini (default):
# GOOGLE_API_KEY=
#
# OpenAI (requires: pip install litellm):
# OPENAI_API_KEY=
#
# Anthropic (requires: pip install litellm):
# ANTHROPIC_API_KEY=
#
# MiniMax (requires: pip install litellm):
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io/v1
#
# Ollama (local, no key needed — just have ollama running):
# OLLAMA_API_BASE=http://localhost:11434

# ─── Model Selection ─────────────────────────────────────────────────────────
# Use ANY model from ANY provider. Format: "provider/model-name"
#
# Gemini (native, no LiteLLM needed):
# DEFAULT_MODEL=gemini-2.0-flash
#
# OpenAI (needs OPENAI_API_KEY + pip install litellm):
# DEFAULT_MODEL=openai/gpt-4o
# DEFAULT_MODEL=openai/gpt-4o-mini
#
# Anthropic (needs ANTHROPIC_API_KEY + pip install litellm):
# DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
# DEFAULT_MODEL=anthropic/claude-3-haiku-20240307
#
# MiniMax (needs MINIMAX_API_KEY + pip install litellm):
DEFAULT_MODEL=minimax/MiniMax-M2.5
#
# Ollama local (needs ollama running + pip install litellm):
# DEFAULT_MODEL=ollama/llama3
# DEFAULT_MODEL=ollama/mistral
# DEFAULT_MODEL=ollama/gemma2
#
# Full provider list: https://docs.litellm.ai/docs/providers

REASONING_MODEL=minimax/MiniMax-M2.5

# ─── External API Keys (optional — falls back to mock data) ──────────────────
SERPAPI_KEY=
ALPHA_VANTAGE_KEY=
SPORTS_API_KEY=
OPENWEATHER_KEY=

# ─── Session & Memory Storage ────────────────────────────────────────────────
SESSION_DB_URL=sqlite:///sessions.db

# Memory service: in_memory | vertex_ai
MEMORY_SERVICE=in_memory

# ─── Vertex AI (required only when MEMORY_SERVICE=vertex_ai) ─────────────────
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
VERTEX_AGENT_ENGINE_ID=

# ─── App Configuration ───────────────────────────────────────────────────────
LOG_LEVEL=INFO

# Environment: development | staging | production
ENVIRONMENT=development
