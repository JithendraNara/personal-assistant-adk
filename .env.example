# Personal Assistant ADK — Environment Configuration
# Copy this file to .env and fill in your values

# ─── LLM Provider (pick ONE — set the key for whichever you use) ──────────────
#
# Gemini (default):
# GOOGLE_API_KEY=
#
# OpenAI (requires: pip install litellm):
# OPENAI_API_KEY=
#
# Anthropic (requires: pip install litellm):
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=             # Optional override (for Anthropic-compatible providers)
#
# MiniMax (requires: pip install litellm):
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io/v1
#
# Ollama (local, no key needed — just have ollama running):
# OLLAMA_API_BASE=http://localhost:11434

# ─── Model Selection ─────────────────────────────────────────────────────────
# Use ANY model from ANY provider. Format: "provider/model-name"
#
# Gemini (native, no LiteLLM needed):
# DEFAULT_MODEL=gemini-2.0-flash
#
# OpenAI (needs OPENAI_API_KEY + pip install litellm):
# DEFAULT_MODEL=openai/gpt-4o
# DEFAULT_MODEL=openai/gpt-4o-mini
#
# Anthropic (needs ANTHROPIC_API_KEY + pip install litellm):
# DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
# DEFAULT_MODEL=anthropic/claude-3-haiku-20240307
#
# MiniMax (needs MINIMAX_API_KEY + pip install litellm):
DEFAULT_MODEL=minimax/MiniMax-M2.5
#
# Ollama local (needs ollama running + pip install litellm):
# DEFAULT_MODEL=ollama/llama3
# DEFAULT_MODEL=ollama/mistral
# DEFAULT_MODEL=ollama/gemma2
#
# Full provider list: https://docs.litellm.ai/docs/providers

# MiniMax Coding Plan API (Anthropic-compatible):
# ANTHROPIC_API_KEY=your_coding_plan_key
# ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# DEFAULT_MODEL=anthropic/MiniMax-M2.5

REASONING_MODEL=minimax/MiniMax-M2.5

# ─── External API Keys (optional — falls back to mock data) ──────────────────
SERPAPI_KEY=
ALPHA_VANTAGE_KEY=
SPORTS_API_KEY=
OPENWEATHER_KEY=

# ─── Session & Memory Storage ────────────────────────────────────────────────
SESSION_DB_URL=sqlite:///sessions.db

# Session service: auto | in_memory | database | vertex_ai
# SESSION_SERVICE=auto

# Memory service: in_memory | vertex_ai | vertex_rag
MEMORY_SERVICE=in_memory

# Artifact service: in_memory | file | gcs
# ARTIFACT_SERVICE=in_memory
# ARTIFACT_FILE_DIR=.adk/artifacts
# ARTIFACT_GCS_BUCKET=

# ─── Vertex AI (required only when MEMORY_SERVICE=vertex_ai) ─────────────────
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
VERTEX_AGENT_ENGINE_ID=
# VERTEX_RAG_CORPUS_ID=

# ─── ADK Runtime Features ─────────────────────────────────────────────────────
# ADK_ENABLE_RESUMABILITY=true
# ADK_ENABLE_CONTEXT_CACHE=false
# ADK_ENABLE_EVENTS_COMPACTION=false
# ADK_DEFAULT_STREAMING_MODE=none
# ADK_SAVE_INPUT_BLOBS=false
# ADK_MAX_LLM_CALLS=500

# ─── App Configuration ───────────────────────────────────────────────────────
LOG_LEVEL=INFO

# Environment: development | staging | production
ENVIRONMENT=development

# API bind settings (defaults to localhost for safety)
HOST=127.0.0.1
PORT=8080

# ─── API Security (recommended for production) ───────────────────────────────
# Comma-separated API tokens accepted via:
#   - X-API-Key header
#   - Authorization: Bearer <token>
#   - WebSocket query param ?api_key=<token>
APP_API_KEY=

# If unset, defaults to: true in production, false otherwise.
# REQUIRE_AUTH=true

# Global inbound API rate limit (per key/IP, per minute).
RATE_LIMIT_PER_MINUTE=60

# Maximum accepted inbound user message length.
MAX_INPUT_CHARS=8000

# Restrict browser origins for API access.
# Example:
# CORS_ORIGINS=https://assistant.example.com,https://admin.example.com

# ─── MCP UnifiedMemory Bridge (optional) ─────────────────────────────────────
# Local UnifiedMemory REST endpoint:
# UM_API_URL=http://127.0.0.1:8082
# UM_API_KEY=
# UM_CONTAINER_TAG=default
# UM_PROFILE_TAG=default
# MCP_HOST=127.0.0.1
# MCP_PORT=8081

# ─── ADK Native Skills (workspace/skills/*) ──────────────────────────────────
# Ensure each skill directory name matches `name:` in SKILL.md.

# ─── ADK Integrations (optional) ─────────────────────────────────────────────
# Built-in Google Search tool
# ENABLE_GOOGLE_SEARCH_TOOL=true
# GOOGLE_SEARCH_AGENTS=research_agent,personal_assistant

# MCP toolset integration
# MCP_SERVER_COMMAND=npx
# MCP_SERVER_ARGS=["-y","@modelcontextprotocol/server-filesystem","/tmp"]
# MCP_SERVER_CWD=
# MCP_SERVER_ENV_JSON={"API_KEY":"..."}
# MCP_AGENTS=research_agent,data_agent,tech_agent,personal_assistant

# OpenAPI toolset integration
# OPENAPI_SPEC_PATH=
# OPENAPI_SPEC_URL=
# OPENAPI_SPEC_JSON=
# OPENAPI_SPEC_TYPE=json
# OPENAPI_TOOL_NAME_PREFIX=
# OPENAPI_AGENTS=research_agent,data_agent,tech_agent,personal_assistant

# External integration plugins (import paths, comma-separated)
# ADK_INTEGRATION_PLUGINS=package.module:PluginClass
