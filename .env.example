# Personal Assistant ADK — Environment Configuration
# Copy this file to .env and fill in your values

# Required
GOOGLE_API_KEY=

# External API Keys (optional — falls back to mock data)
SERPAPI_KEY=
ALPHA_VANTAGE_KEY=
SPORTS_API_KEY=
OPENWEATHER_KEY=

# Session & Memory Storage
SESSION_DB_URL=sqlite:///sessions.db

# Memory service: in_memory | vertex_ai
MEMORY_SERVICE=in_memory

# Vertex AI (required only when MEMORY_SERVICE=vertex_ai)
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
VERTEX_AGENT_ENGINE_ID=

# Model Configuration (optional overrides)
DEFAULT_MODEL=gemini-2.0-flash
REASONING_MODEL=gemini-2.0-flash

# App Configuration
LOG_LEVEL=INFO

# Environment: development | staging | production
ENVIRONMENT=development
