# Required

# Google Gemini API key — get one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Web Search
# SerpApi for real Google search results (research_agent)
# Get a key at https://serpapi.com
SERPAPI_KEY=

# NewsAPI for real news headlines (research_agent)
# Get a key at https://newsapi.org
NEWS_API_KEY=

# Optional: Finance
# Alpha Vantage for real stock quotes (finance_agent)
# Get a free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# Plaid for bank account data integration (finance_agent)
# Get credentials at https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Optional: Sports
# API-Sports.io for NFL, F1, and more (sports_agent)
# Get a key at https://api-sports.io
SPORTS_API_KEY=

# CricAPI for cricket scores (sports_agent)
# Get a key at https://cricapi.com
CRICAPI_KEY=

# Optional: Career / Jobs
# RapidAPI key for JSearch (LinkedIn job listings) (career_agent)
# Get a key at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=

# Optional: Session Persistence
# Path for SQLite session database (uncomment DatabaseSessionService in run.py)
SESSION_DB_PATH=sessions.db

# Set to "true" to enable persistent sessions (requires DatabaseSessionService)
USE_PERSISTENT_SESSIONS=false

# Optional: Google Cloud (for Vertex AI production deployment)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
